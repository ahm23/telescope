{
  "name": "@ahm23/telescope-proto-parser",
  "version": "2.2.1",
  "description": "A Parser for Cosmos Protobufs",
  "author": "Constructive <developers@constructive.io>",
  "homepage": "https://github.com/ahm23/telescope",
  "license": "MIT",
  "main": "index.js",
  "module": "esm/index.js",
  "types": "index.d.ts",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ahm23/telescope"
  },
  "scripts": {
    "clean": "makage clean",
    "prepack": "npm run build",
    "build": "makage build",
    "build:dev": "makage build --dev",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect node_modules/.bin/jest --runInBand"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.ts?$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "<rootDir>/node_modules/"
    ],
    "testPathIgnorePatterns": [
      "dist/"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/dist/"
    ]
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/hyperweb-io/telescope/issues"
  },
  "devDependencies": {
    "deepmerge": "4.3.1",
    "jest-in-case": "^1.0.2",
    "long": "^5.2.1",
    "makage": "^0.1.12"
  },
  "dependencies": {
    "@ahm23/telescope-types": "workspace:*",
    "@ahm23/telescope-utils": "workspace:*",
    "@cosmology/protobufjs": "7.3.2",
    "dotty": "0.1.2",
    "fast-json-patch": "3.1.1",
    "glob": "8.0.3",
    "minimatch": "5.1.0",
    "mkdirp": "3.0.0"
  }
}
