{
  "name": "@cosmology/starship-test",
  "private": true,
  "version": "2.1.0",
  "description": "E2E tests for telescope with Starship",
  "author": "Constructive <developers@constructive.io>",
  "homepage": "https://github.com/hyperweb-io/telescope",
  "license": "MIT",
  "main": "index.js",
  "types": "index.d.ts",
  "publishConfig": {
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hyperweb-io/telescope"
  },
  "scripts": {
    "clean": "makage clean && rimraf ./src/codegen && rimraf ./src/codegen1",
    "prepack": "npm run build",
    "build": "makage build",
    "build:dev": "makage build --dev",
    "codegen": "npm run clean && cross-env NODE_ENV=development ts-node scripts/codegen.js",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "starship": "starship --config configs/config.yaml",
    "starship:test": "jest --testPathPattern=__tests__/ --verbose --bail",
    "starship:debug": "jest --testPathPattern=__tests__/ --runInBand --verbose --bail",
    "starship:watch": "jest --watch --testPathPattern=__tests__/"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.ts?$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "<rootDir>/node_modules/"
    ],
    "testPathIgnorePatterns": [
      "dist/"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/dist/"
    ]
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/hyperweb-io/telescope/issues"
  },
  "devDependencies": {
    "@confio/relayer": "0.7.0",
    "@cosmjs/crypto": "0.29.4",
    "@hyperweb/telescope": "workspace:*",
    "@protobufs/confio": "^0.0.6",
    "@protobufs/cosmos": "^0.0.11",
    "@protobufs/cosmos_proto": "^0.0.10",
    "@protobufs/gogoproto": "^0.0.10",
    "@protobufs/google": "^0.0.10",
    "@protobufs/ibc": "^0.0.11",
    "@protobufs/osmosis": "^0.2.0",
    "@protobufs/tendermint": "^0.0.10",
    "@starship-ci/cli": "^3.0.0",
    "ast-stringify": "0.1.0",
    "axios": "^1.7.4",
    "bignumber.js": "9.1.0",
    "case": "1.6.3",
    "cosmjs-types": "0.5.2",
    "cross-env": "^7.0.2",
    "glob": "8.0.3",
    "@interchainjs/crypto": "1.17.1",
    "interchainjs": "1.17.1",
    "js-yaml": "4.1.0",
    "makage": "^0.1.12",
    "mkdirp": "3.0.0",
    "mobx": "6.9.0",
    "node-fetch": "^2.6.9",
    "path": "^0.12.7",
    "rimraf": "5.0.0",
    "sinon": "14.0.2",
    "starshipjs": "^3.0.0",
    "ts-node": "10.9.1"
  },
  "dependencies": {
    "@chain-registry/v2": "^1.71.237",
    "@cosmjs/amino": "^0.32.0",
    "@cosmjs/proto-signing": "^0.32.0",
    "@cosmjs/stargate": "^0.32.0",
    "@cosmjs/tendermint-rpc": "^0.32.0",
    "@cosmology/core": "1.23.0",
    "@cosmology/lcd": "workspace:*",
    "@keplr-wallet/unit": "0.11.56",
    "@tanstack/react-query": "4.29.1",
    "cosmjs-utils": "0.1.0",
    "long": "^5.2.1",
    "protobufjs": "^6.11.3",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
