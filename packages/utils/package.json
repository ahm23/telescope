{
  "name": "@cosmology/utils",
  "version": "2.1.0",
  "description": "Telescope utils",
  "author": "Constructive <developers@constructive.io>",
  "homepage": "https://github.com/hyperweb-io/telescope",
  "license": "MIT",
  "main": "index.js",
  "module": "esm/index.js",
  "types": "index.d.ts",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hyperweb-io/telescope"
  },
  "scripts": {
    "clean": "makage clean",
    "prepack": "npm run build",
    "build": "makage build",
    "build:dev": "makage build --dev",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect node_modules/.bin/jest --runInBand"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.ts?$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "<rootDir>/node_modules/"
    ],
    "testPathIgnorePatterns": [
      "dist/"
    ]
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/hyperweb-io/telescope/issues"
  },
  "devDependencies": {
    "makage": "^0.1.12"
  },
  "dependencies": {
    "@babel/types": "7.23.6",
    "@cosmology/types": "workspace:*",
    "case": "1.6.3",
    "dotty": "0.1.2",
    "glob": "8.0.3",
    "minimatch": "5.1.0"
  }
}
