{
  "name": "@hyperweb/telescope",
  "version": "2.2.1",
  "description": "A TypeScript Transpiler for Cosmos Protobufs",
  "author": "Constructive <developers@constructive.io>",
  "homepage": "https://github.com/hyperweb-io/telescope",
  "license": "MIT",
  "main": "index.js",
  "module": "esm/index.js",
  "types": "index.d.ts",
  "bin": {
    "telescope": "telescope.js"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hyperweb-io/telescope"
  },
  "scripts": {
    "clean": "makage clean",
    "prepack": "npm run build",
    "build": "makage build",
    "build:dev": "makage build --dev",
    "dev": "cross-env NODE_ENV=development ts-node src/telescope",
    "watch": "cross-env NODE_ENV=development ts-node-dev src/telescope",
    "file": "cross-env NODE_ENV=development ts-node-dev src/file",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "test": "jest",
    "test:funcs": "jest __tests__/telescope-helper-func.test.ts",
    "test:min": "jest __tests__/telescope-v4.test.ts",
    "test:misc": "jest __tests__/misc.test.ts",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect node_modules/.bin/jest --runInBand"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.ts?$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "<rootDir>/node_modules/"
    ],
    "testPathIgnorePatterns": [
      "dist/",
      "git-modules"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/dist/"
    ]
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/hyperweb-io/telescope/issues"
  },
  "devDependencies": {
    "@keplr-wallet/unit": "^0.12.53",
    "@types/minimist": "^1.2.5",
    "ast-stringify": "0.1.0",
    "cross-env": "^7.0.2",
    "makage": "^0.1.12",
    "ts-node": "10.9.1",
    "ts-node-dev": "2.0.0"
  },
  "dependencies": {
    "@babel/generator": "^7.23.6",
    "@babel/parser": "^7.23.6",
    "@babel/traverse": "7.23.6",
    "@babel/types": "7.23.6",
    "@cosmology/ast": "workspace:*",
    "@cosmology/proto-parser": "workspace:*",
    "@cosmology/types": "workspace:*",
    "@cosmology/utils": "workspace:*",
    "@types/parse-package-name": "0.1.0",
    "case": "1.6.3",
    "dargs": "7.0.0",
    "deepmerge": "4.3.1",
    "dotty": "0.1.2",
    "find-and-require-package-json": "^0.9.1",
    "fuzzy": "0.1.3",
    "glob": "8.0.3",
    "inquirerer": "0.1.3",
    "long": "^5.2.1",
    "minimatch": "5.1.0",
    "minimist": "1.2.8",
    "mkdirp": "3.0.0",
    "parse-package-name": "1.0.0",
    "rimraf": "5.0.0",
    "shelljs": "^0.8.5",
    "yaml": "^2.3.4"
  }
}
